<mvc:View
    controllerName="myapp.controller.PurchaseOrderDetail"
    xmlns:mvc="sap.ui.core.mvc"
    xmlns="sap.m"
    xmlns:core="sap.ui.core">
    <Page title="{i18n>purchaseOrderListTitle}" showNavButton="true" navButtonPress="onNavBack" class="poDetailPage">
        <headerContent>
            <Button text="{i18n>saveButton}" press="onSave" type="Emphasized" visible="{ui>/canEditOrder}" />
            <Button text="{i18n>poSubmitApprovalButton}" press="onSubmitApproval" type="Emphasized" visible="{ui>/canSubmit}" />
            <Button text="{i18n>poApproveButton}" press="onApprove" type="Accept" visible="{ui>/canApprove}" />
            <Button text="{i18n>poRejectButton}" press="onReject" type="Reject" visible="{ui>/canReject}" />
            <Button text="{i18n>cancelButton}" press="onCancel" />
        </headerContent>
        <content>
            <VBox class="poDetailLayout">
                <HBox class="poDetailTopRow" wrap="Wrap" renderType="Bare">
                    <Panel class="poDetailHeaderPanel poHeaderBandPanel">
                        <headerToolbar>
                            <Toolbar class="poHeaderBandToolbar">
                                <Title text="{i18n>poHeaderSection}" level="H4" />
                                <ToolbarSpacer />
                                <ObjectStatus
                                    text="{ path: 'purchaseOrders>status', formatter: '.formatOrderStatusText' }"
                                    state="{ path: 'purchaseOrders>status', formatter: '.formatOrderStatusState' }"
                                    class="poHeaderBandStatus" />
                            </Toolbar>
                        </headerToolbar>
                        <FlexBox wrap="Wrap" renderType="Bare" class="poHeaderBandGrid">
                            <VBox class="poHeaderField poHeaderFieldShort">
                                <Text text="{i18n>poId}" class="poHeaderFieldLabel" />
                                <Input value="{purchaseOrders>id}" editable="false" class="poHeaderFieldInput" />
                            </VBox>
                            <VBox class="poHeaderField poHeaderFieldWide">
                                <Text text="{i18n>supplierId}" class="poHeaderFieldLabel" />
                                <Select selectedKey="{purchaseOrders>supplierId}" change="onPricingConditionChange" items="{selectOptions>/supplierOptions}" class="poHeaderFieldInput" forceSelection="false" enabled="{ui>/canEditOrder}">
                                    <items>
                                        <core:Item key="{selectOptions>id}" text="{= ${selectOptions>id} ? ${selectOptions>id} + ' - ' + ${selectOptions>name} : ${selectOptions>name} }" />
                                    </items>
                                </Select>
                            </VBox>
                            <VBox class="poHeaderField poHeaderFieldMedium">
                                <Text text="{i18n>poVendor}" class="poHeaderFieldLabel" />
                                <Input value="{purchaseOrders>vendor}" editable="false" class="poHeaderFieldInput" />
                            </VBox>
                            <VBox class="poHeaderField poHeaderFieldShort">
                                <Text text="{i18n>poDate}" class="poHeaderFieldLabel" />
                                <DatePicker value="{purchaseOrders>date}" valueFormat="yyyy-MM-dd" displayFormat="yyyy-MM-dd" change="onPricingConditionChange" class="poHeaderFieldInput" enabled="{ui>/canEditOrder}" />
                            </VBox>
                            <VBox class="poHeaderField poHeaderFieldShort">
                                <Text text="{i18n>poStatus}" class="poHeaderFieldLabel" />
                                <Select selectedKey="{purchaseOrders>status}" class="poHeaderFieldInput" forceSelection="false" items="{statusOptions>/orderStatus}" enabled="{ui>/canEditOrder}">
                                    <items>
                                        <core:Item key="{statusOptions>key}" text="{statusOptions>text}" />
                                    </items>
                                </Select>
                            </VBox>
                        </FlexBox>
                    </Panel>

                    <VBox class="poDetailSummaryColumn">
                        <Panel class="poSummaryHeroPanel">
                            <VBox class="poSummaryHeroContent">
                                <Text text="{i18n>poStatus}" class="poSummaryEyebrow" />
                                <ObjectStatus
                                    text="{ path: 'purchaseOrders>status', formatter: '.formatOrderStatusText' }"
                                    state="{ path: 'purchaseOrders>status', formatter: '.formatOrderStatusState' }"
                                    class="poSummaryStatus" />
                                <Title text="{purchaseOrders>vendor}" level="H3" class="poSummaryTitle sapUiSmallMarginTop" />
                                <Text text="{= ${purchaseOrders>id} + ' / ' + ${purchaseOrders>date}}" class="poSummarySubtext sapUiTinyMarginTop" />
                            </VBox>
                        </Panel>

                        <Panel headerText="{i18n>poApprovalSection}" class="sapUiSmallMarginTop">
                            <VBox class="sapUiSmallMargin">
                                <ObjectStatus text="{purchaseOrders>approvalStatusText}" state="{purchaseOrders>approvalStatusState}" class="sapUiTinyMarginBottom" />
                                <Text text="{= ${i18n>poProcessModel} + ': ' + ${purchaseOrders>processModelName}}" />
                                <Text text="{= ${i18n>poCreatedBy} + ': ' + ${purchaseOrders>createdBy} + ' / ' + ${purchaseOrders>creatorRole}}" />
                                <Text text="{= ${i18n>poSubmittedBy} + ': ' + (${purchaseOrders>submittedBy} || '-') }" />
                                <Text text="{= ${i18n>poSubmittedAt} + ': ' + (${purchaseOrders>submittedAt} || '-') }" />
                                <Text text="{= ${i18n>poCurrentApprover} + ': ' + ((${purchaseOrders>currentApprover} &amp;&amp; ${purchaseOrders>currentApproverRole}) ? ${purchaseOrders>currentApprover} + ' / ' + ${purchaseOrders>currentApproverRole} : '-') }" />
                                <Text text="{= ${i18n>poApprovedBy} + ': ' + (${purchaseOrders>approvedBy} || '-') }" />
                                <Text text="{= ${i18n>poApprovedAt} + ': ' + (${purchaseOrders>approvedAt} || '-') }" />
                                <Text text="{= ${i18n>poApprovalComment} + ': ' + (${purchaseOrders>approvalComment} || '-') }" />
                            </VBox>
                        </Panel>

                        <HBox class="poMetricGrid" wrap="Wrap" renderType="Bare">
                            <VBox class="poMetricCard">
                                <Text text="{i18n>poItemCount}" class="poMetricLabel" />
                                <Title text="{purchaseOrders>itemCount}" level="H3" class="poMetricValue" />
                            </VBox>
                            <VBox class="poMetricCard">
                                <Text text="{i18n>poTotalQuantity}" class="poMetricLabel" />
                                <Title text="{purchaseOrders>totalQuantity}" level="H3" class="poMetricValue" />
                            </VBox>
                            <VBox class="poMetricCard poMetricCardWide">
                                <Text text="{i18n>poAmount}" class="poMetricLabel" />
                                <Title text="{= ${purchaseOrders>currency} + ' ' + ${purchaseOrders>amount}}" level="H3" class="poMetricValue" />
                            </VBox>
                        </HBox>
                    </VBox>
                </HBox>

                <Panel headerText="{i18n>poLineItemsSection}" class="poLineItemsPanel">
                    <headerToolbar>
                        <Toolbar class="poLineItemsToolbar">
                            <Title text="{i18n>poLineItemsSection}" level="H4" />
                            <ToolbarSpacer />
                                <Button text="{i18n>btnAdd}" icon="sap-icon://add" press="onAddItem" visible="{ui>/canEditOrder}" />
                        </Toolbar>
                    </headerToolbar>
                    <Table items="{purchaseOrders>items}" class="poLineItemsTable">
                        <columns>
                            <Column width="5rem" hAlign="Center"><Text text="{i18n>poLineNo}" /></Column>
                            <Column width="18rem"><Text text="{i18n>materialId}" /></Column>
                            <Column width="8rem" hAlign="End"><Text text="{i18n>poQuantity}" /></Column>
                            <Column width="6rem" hAlign="Center"><Text text="{i18n>unit}" /></Column>
                            <Column width="10rem" hAlign="End"><Text text="{i18n>poUnitPrice}" /></Column>
                            <Column width="11rem" hAlign="End"><Text text="{i18n>poAmount}" /></Column>
                            <Column width="10rem" hAlign="Center"><Text text="{i18n>priceMatchStatus}" /></Column>
                            <Column width="12rem" hAlign="Center"><Text text="{i18n>poBenchmark}" /></Column>
                            <Column width="5rem" hAlign="Center"><Text text="{i18n>actions}" /></Column>
                        </columns>
                        <items>
                            <ColumnListItem class="poLineItemRow">
                                <cells>
                                    <Text text="{purchaseOrders>lineId}" textAlign="Center" class="poCellText" />
                                    <Select selectedKey="{purchaseOrders>materialId}" change="onPricingConditionChange" items="{selectOptions>/materialOptions}" class="poCellSelect" forceSelection="false" enabled="{ui>/canEditOrder}">
                                        <items>
                                            <core:Item key="{selectOptions>id}" text="{= ${selectOptions>id} ? ${selectOptions>id} + ' - ' + ${selectOptions>name} : ${selectOptions>name} }" />
                                        </items>
                                    </Select>
                                    <Input value="{purchaseOrders>quantity}" type="Number" liveChange="onPricingConditionChange" textAlign="End" class="poCellInput poCellNumber" editable="{ui>/canEditOrder}" />
                                    <Text text="{purchaseOrders>unit}" textAlign="Center" class="poCellText" />
                                    <Text text="{= ${purchaseOrders>currency} + ' ' + ${purchaseOrders>unitPrice}}" textAlign="End" class="poCellText poCellNumberText" />
                                    <Text text="{= ${purchaseOrders>currency} + ' ' + ${purchaseOrders>amount}}" textAlign="End" class="poCellText poCellNumberText poCellAmountText" />
                                    <ObjectStatus text="{ path: 'purchaseOrders>priceStatusText', formatter: '.formatPriceMatchText' }" state="{purchaseOrders>priceStatusState}" class="poCellStatus" />
                                    <ObjectStatus text="{purchaseOrders>priceBenchmarkText}" state="{purchaseOrders>priceBenchmarkState}" class="poCellStatus" />
                                    <Button icon="sap-icon://delete" type="Reject" press="onDeleteItem" class="poRowDeleteButton" visible="{ui>/canEditOrder}" />
                                </cells>
                            </ColumnListItem>
                        </items>
                    </Table>
                </Panel>
            </VBox>
        </content>
    </Page>
</mvc:View>