<mvc:View
    controllerName="myapp.controller.ProcessManagement"
    xmlns:mvc="sap.ui.core.mvc"
    xmlns="sap.m"
    xmlns:layout="sap.ui.layout"
    xmlns:core="sap.ui.core">
    <Page title="流程管理" showNavButton="true" navButtonPress="onNavBack">
        <VBox class="sapUiContentPadding" spacing="1rem">
            <TabContainer id="processTabContainer" selectedKey="categories">
                <items>
                    <TabContainerItem key="categories" name="流程分类">
                        <content>
                            <Table items="{process>/processCategories}">
                                <columns>
                                    <Column><Text text="分类ID" /></Column>
                                    <Column><Text text="分类名称" /></Column>
                                </columns>
                                <items>
                                    <ColumnListItem>
                                        <cells>
                                            <Text text="{process>id}" />
                                            <Text text="{process>name}" />
                                        </cells>
                                    </ColumnListItem>
                                </items>
                            </Table>
                        </content>
                    </TabContainerItem>
                    <TabContainerItem key="forms" name="表单配置">
                        <content>
                            <Table items="{process>/formConfigs}">
                            <columns>
                                <Column><Text text="表单ID" /></Column>
                                <Column><Text text="表单名称" /></Column>
                                <Column><Text text="字段" /></Column>
                            </columns>
                            <items>
                                <ColumnListItem>
                                    <cells>
                                        <Text text="{process>id}" />
                                        <Text text="{process>name}" />
                                        <Text text="{= ${process>fields}.join(', ') }" />
                                    </cells>
                                </ColumnListItem>
                            </items>
                        </Table>
                        </content>
                    </TabContainerItem>
                    <TabContainerItem key="models" name="流程模型">
                        <content>
                            <Table items="{process>/processModels}">
                            <columns>
                                <Column><Text text="模型ID" /></Column>
                                <Column><Text text="模型名称" /></Column>
                                <Column><Text text="版本" /></Column>
                                <Column><Text text="状态" /></Column>
                            </columns>
                            <items>
                                <ColumnListItem>
                                    <cells>
                                        <Text text="{process>id}" />
                                        <Text text="{process>name}" />
                                        <Text text="{process>version}" />
                                        <Text text="{process>status}" />
                                    </cells>
                                </ColumnListItem>
                            </items>
                        </Table>
                        </content>
                    </TabContainerItem>
                    <TabContainerItem key="deployment" name="部署管理">
                        <content>
                            <Table items="{process>/deployments}">
                            <columns>
                                <Column><Text text="部署ID" /></Column>
                                <Column><Text text="模型名称" /></Column>
                                <Column><Text text="部署时间" /></Column>
                                <Column><Text text="状态" /></Column>
                            </columns>
                            <items>
                                <ColumnListItem>
                                    <cells>
                                        <Text text="{process>id}" />
                                        <Text text="{process>modelName}" />
                                        <Text text="{process>deployTime}" />
                                        <ObjectStatus text="{process>status}" state="{= ${process>status} === '成功' ? 'Success' : ${process>status} === '失败' ? 'Error' : 'Information' }" />
                                    </cells>
                                </ColumnListItem>
                            </items>
                        </Table>                        </content>                    </TabContainerItem>
                </items>
            </TabContainer>
        </VBox>
    </Page>
</mvc:View>