<mvc:View
    controllerName="myapp.controller.DeploymentList"
    xmlns:mvc="sap.ui.core.mvc"
    xmlns="sap.m"
    xmlns:core="sap.ui.core">
    <Page title="部署管理" showNavButton="true" navButtonPress="onNavBack">
        <VBox class="sapUiContentPadding" width="100%">
            <Text text="部署列表" class="sapUiTinyMarginBottom" />
            <Table items="{process>/deployments}">
                <columns>
                    <Column><Text text="部署ID" /></Column>
                    <Column><Text text="模型名称" /></Column>
                    <Column><Text text="部署时间" /></Column>
                    <Column><Text text="状态" /></Column>
                </columns>
                <items>
                    <ColumnListItem>
                        <cells>
                            <Text text="{process>id}" />
                            <Text text="{process>modelName}" />
                            <Text text="{process>deployTime}" />
                            <Text text="{process>status}" />
                        </cells>
                    </ColumnListItem>
                </items>
            </Table>
        </VBox>
    </Page>
</mvc:View>