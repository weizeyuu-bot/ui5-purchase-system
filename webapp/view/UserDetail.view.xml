<mvc:View
    controllerName="myapp.controller.UserDetail"
    xmlns:mvc="sap.ui.core.mvc"
    xmlns="sap.m"
    xmlns:layout="sap.ui.layout"
    xmlns:form="sap.ui.layout.form">
    <Page title="{i18n>userDetailTitle}" showNavButton="true" navButtonPress="onNavBack">
        <VBox class="sapUiContentPadding sapUiLargeMargin">
            <!-- Header -->
            <VBox class="sapUiSmallMarginBottom">
                <Title text="{i18n>userDetailTitle}" level="H1" />
                <HBox class="sapUiSmallMarginTop">
                    <ObjectStatus 
                        text="{userDetail>status}"
                        state="{userDetail>statusState}" />
                    <Text text="ID: {userDetail>username}" class="sapUiSmallMargin" />
                </HBox>
            </VBox>

            <!-- Basic Information Panel -->
            <Panel headerText="{i18n>basicInformation}" class="sapUiLargeMarginBottom">
                <form:Form editable="false">
                    <form:layout>
                        <form:ResponsiveGridLayout columnsL="2" columnsM="2" labelSpanL="4" labelSpanM="4" emptySpanL="1" emptySpanM="1" />
                    </form:layout>
                    <form:formContainers>
                        <form:FormContainer>
                            <form:formElements>
                                <form:FormElement label="{i18n>username}">
                                    <form:fields>
                                        <Text text="{userDetail>username}" />
                                    </form:fields>
                                </form:FormElement>
                                <form:FormElement label="{i18n>userEmail}">
                                    <form:fields>
                                        <Text text="{userDetail>email}" />
                                    </form:fields>
                                </form:FormElement>
                                <form:FormElement label="{i18n>userPhone}">
                                    <form:fields>
                                        <Text text="{userDetail>phone}" />
                                    </form:fields>
                                </form:FormElement>
                                <form:FormElement label="{i18n>department}">
                                    <form:fields>
                                        <Text text="{userDetail>department}" />
                                    </form:fields>
                                </form:FormElement>
                            </form:formElements>
                        </form:FormContainer>
                        <form:FormContainer>
                            <form:formElements>
                                <form:FormElement label="{i18n>role}">
                                    <form:fields>
                                        <Text text="{userDetail>role}" />
                                    </form:fields>
                                </form:FormElement>
                                <form:FormElement label="{i18n>status}">
                                    <form:fields>
                                        <ObjectStatus 
                                            text="{userDetail>status}"
                                            state="{userDetail>statusState}" />
                                    </form:fields>
                                </form:FormElement>
                                <form:FormElement label="{i18n>registrationDate}">
                                    <form:fields>
                                        <Text text="{userDetail>registrationDate}" />
                                    </form:fields>
                                </form:FormElement>
                                <form:FormElement label="{i18n>createdBy}">
                                    <form:fields>
                                        <Text text="{userDetail>createdBy}" />
                                    </form:fields>
                                </form:FormElement>
                            </form:formElements>
                        </form:FormContainer>
                    </form:formContainers>
                </form:Form>
            </Panel>

            <!-- Login Information Panel -->
            <Panel headerText="{i18n>loginInformation}" class="sapUiLargeMarginBottom">
                <form:Form editable="false">
                    <form:layout>
                        <form:ResponsiveGridLayout columnsL="1" columnsM="1" labelSpanL="4" labelSpanM="4" emptySpanL="0" emptySpanM="0" />
                    </form:layout>
                    <form:formContainers>
                        <form:FormContainer>
                            <form:formElements>
                                <form:FormElement label="{i18n>lastLogin}">
                                    <form:fields>
                                        <Text text="{userDetail>lastLogin}" />
                                    </form:fields>
                                </form:FormElement>
                                <form:FormElement label="{i18n>loginCount}">
                                    <form:fields>
                                        <Text text="{userDetail>loginCount}" />
                                    </form:fields>
                                </form:FormElement>
                            </form:formElements>
                        </form:FormContainer>
                    </form:formContainers>
                </form:Form>
            </Panel>

            <!-- Action Buttons -->
            <HBox class="sapUiLargeMarginTop">
                <Button text="{i18n>editButton}" icon="sap-icon://edit" type="Emphasized" press="onEditUser" />
                <Button text="{i18n>back}" icon="sap-icon://nav-back" press="onNavBack" />
            </HBox>
        </VBox>
    </Page>
</mvc:View>