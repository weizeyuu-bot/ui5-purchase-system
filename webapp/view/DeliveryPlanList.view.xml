<mvc:View
    controllerName="myapp.controller.DeliveryPlanList"
    xmlns:mvc="sap.ui.core.mvc"
    xmlns="sap.m">
    <Page title="{i18n>deliveryPlanListTitle}" showNavButton="true" navButtonPress="onNavBack">
        <subHeader>
            <Toolbar>
                <Button icon="sap-icon://add" text="新增" press="onAdd" type="Emphasized" />
                <SearchField placeholder="{i18n>filterPlaceholder}" search="onSearch" width="100%" />
            </Toolbar>
        </subHeader>
        <content>
            <Table id="deliveryTable" class="supplierTable" items="{deliveryPlans>/deliveryPlans}">
                <columns>
                    <Column>
                        <Text text="{i18n>deliveryId}" />
                    </Column>
                    <Column>
                        <Text text="{i18n>deliveryDate}" />
                    </Column>
                    <Column>
                        <Text text="{i18n>deliveryStatus}" />
                    </Column>
                    <Column>
                        <Text text="{i18n>poId}" />
                    </Column>
                </columns>
                <items>
                    <ColumnListItem type="Navigation" press="onItemPress">
                        <cells>
                            <Text text="{deliveryPlans>id}" />
                            <Text text="{deliveryPlans>date}" />
                            <Text text="{deliveryPlans>status}" />
                            <Link text="{deliveryPlans>purchaseOrderId}" press="onNavigateToPurchaseOrder" />
                            <HBox>
                                <Button text="查看" press="onViewPress" />
                                <Button text="编辑" press="onEditPress" />
                                <Button icon="sap-icon://delete" type="Reject" press="onDeletePress" />
                            </HBox>
                        </cells>
                    </ColumnListItem>
                </items>
            </Table>
        </content>
        <Dialog id="dpDialog" title="送货计划管理" type="Standard">
            <content>
                <VBox class="sapUiContentPadding">
                    <Label text="计划号" required="true" />
                    <Input id="dpPlanNumberInput" value="{oNewDP>/planNumber}" />
                    <Label text="采购订单" />
                    <Input id="dpPOInput" value="{oNewDP>/purchaseOrderId}" />
                    <Label text="送货日期" />
                    <Input id="dpDateInput" value="{oNewDP>/deliveryDate}" />
                    <Label text="数量" />
                    <Input id="dpQtyInput" value="{oNewDP>/quantity}" type="Number" />
                    <Label text="状态" />
                    <Input id="dpStatusInput" value="{oNewDP>/status}" />
                </VBox>
            </content>
            <beginButton>
                <Button text="保存" press="onDialogSave" type="Emphasized" />
            </beginButton>
            <endButton>
                <Button text="取消" press="onDialogCancel" />
            </endButton>
        </Dialog>
    </Page>
</mvc:View>