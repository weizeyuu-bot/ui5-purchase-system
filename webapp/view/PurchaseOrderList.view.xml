<mvc:View
    controllerName="myapp.controller.PurchaseOrderList"
    xmlns:mvc="sap.ui.core.mvc"
    xmlns="sap.m"
    xmlns:core="sap.ui.core">
    <Page title="{i18n>purchaseOrderListTitle}" showNavButton="true" navButtonPress="onNavBack">
        <subHeader>
            <Toolbar>
                <Button icon="sap-icon://add" text="{i18n>btnAdd}" press="onAdd" type="Emphasized" />
                <SearchField placeholder="{i18n>filterPlaceholder}" search="onSearch" width="100%" />
            </Toolbar>
        </subHeader>
        <content>
            <Table id="poTable" class="supplierTable" items="{purchaseOrders>/purchaseOrders}">
                <columns>
                    <Column>
                        <Text text="{i18n>poId}" />
                    </Column>
                    <Column>
                        <Text text="{i18n>poVendor}" />
                    </Column>
                    <Column>
                        <Text text="{i18n>poDate}" />
                    </Column>
                    <Column>
                        <Text text="{i18n>poStatus}" />
                    </Column>
                    <Column>
                        <Text text="{i18n>poApprovalStatus}" />
                    </Column>
                    <Column>
                        <Text text="{i18n>poCurrentApprover}" />
                    </Column>
                    <Column>
                        <Text text="{i18n>poItemCount}" />
                    </Column>
                    <Column>
                        <Text text="{i18n>poTotalQuantity}" />
                    </Column>
                    <Column>
                        <Text text="{i18n>poAmount}" />
                    </Column>
                    <Column>
                        <Text text="{i18n>actions}" />
                    </Column>
                </columns>
                <items>
                    <ColumnListItem type="Navigation" press="onItemPress">
                        <cells>
                            <Text text="{purchaseOrders>id}" />
                            <Text text="{purchaseOrders>vendor}" />
                            <Text text="{purchaseOrders>date}" />
                            <Text text="{ path: 'purchaseOrders>status', formatter: '.formatOrderStatusText' }" />
                            <ObjectStatus text="{purchaseOrders>approvalStatusText}" state="{purchaseOrders>approvalStatusState}" />
                            <Text text="{= ${purchaseOrders>currentApprover} ? ${purchaseOrders>currentApprover} + ' / ' + ${purchaseOrders>currentApproverRole} : '-' }" />
                            <Text text="{purchaseOrders>itemCount}" />
                            <Text text="{purchaseOrders>totalQuantity}" />
                            <Text text="{= ${purchaseOrders>currency} + ' ' + ${purchaseOrders>amount}}" />
                            <HBox>
                                <Button
                                    text="{i18n>poSubmitApprovalButton}"
                                    type="Emphasized"
                                    visible="{parts:[{path:'purchaseOrders>approvalStatus'},{path:'purchaseOrders>createdBy'}], formatter:'.isQuickSubmitVisible'}"
                                    press="onQuickSubmitApproval" />
                                <Button
                                    text="{i18n>poApproveButton}"
                                    type="Accept"
                                    visible="{parts:[{path:'purchaseOrders>approvalStatus'},{path:'purchaseOrders>currentApprover'}], formatter:'.isQuickApproveVisible'}"
                                    press="onQuickApprove" />
                                <Button
                                    text="{i18n>poRejectButton}"
                                    type="Reject"
                                    visible="{parts:[{path:'purchaseOrders>approvalStatus'},{path:'purchaseOrders>currentApprover'}], formatter:'.isQuickRejectVisible'}"
                                    press="onQuickReject" />
                                <Button text="{i18n>viewButton}" press="onViewPress" />
                                <Button text="{i18n>editButton}" press="onEditPress" />
                                <Button icon="sap-icon://delete" type="Reject" press="onDeletePress" />
                            </HBox>
                        </cells>
                    </ColumnListItem>
                </items>
            </Table>
        </content>
        <Dialog id="poDialog" title="{i18n>menuPurchaseOrders}" type="Standard">
            <content>
                <VBox class="sapUiContentPadding">
                    <Panel headerText="{i18n>poHeaderSection}">
                        <VBox class="sapUiSmallMargin">
                            <Label text="{i18n>poId}" required="true" />
                            <Input id="poNumberInput" value="{oNewPO>/id}" />
                            <Label text="{i18n>supplierId}" />
                            <Select selectedKey="{oNewPO>/supplierId}" change="onPricingConditionChange" items="{oNewPO>/supplierOptions}" forceSelection="false">
                                <items>
                                    <core:Item key="{oNewPO>id}" text="{= ${oNewPO>id} ? ${oNewPO>id} + ' - ' + ${oNewPO>name} : ${oNewPO>name} }" />
                                </items>
                            </Select>
                            <Label text="{i18n>poDate}" />
                            <DatePicker value="{oNewPO>/date}" valueFormat="yyyy-MM-dd" displayFormat="yyyy-MM-dd" change="onPricingConditionChange" />
                            <Label text="{i18n>status}" />
                            <Select selectedKey="{oNewPO>/status}" forceSelection="false" items="{statusOptions>/orderStatusWithBlank}">
                                <items>
                                    <core:Item key="{statusOptions>key}" text="{statusOptions>text}" />
                                </items>
                            </Select>
                            <Label text="{i18n>poItemCount}" />
                            <Input value="{oNewPO>/itemCount}" editable="false" />
                            <Label text="{i18n>poTotalQuantity}" />
                            <Input value="{oNewPO>/totalQuantity}" editable="false" />
                            <Label text="{i18n>poAmount}" />
                            <Input id="poAmountInput" value="{= ${oNewPO>/currency} + ' ' + ${oNewPO>/amount}}" editable="false" />
                        </VBox>
                    </Panel>

                    <Panel headerText="{i18n>poLineItemsSection}" class="sapUiSmallMarginTop">
                        <headerToolbar>
                            <Toolbar>
                                <Title text="{i18n>poLineItemsSection}" level="H4" />
                                <ToolbarSpacer />
                                <Button text="{i18n>btnAdd}" icon="sap-icon://add" press="onAddDraftItem" />
                            </Toolbar>
                        </headerToolbar>
                        <Table items="{oNewPO>/items}">
                            <columns>
                                <Column><Text text="{i18n>poLineNo}" /></Column>
                                <Column><Text text="{i18n>materialId}" /></Column>
                                <Column><Text text="{i18n>poQuantity}" /></Column>
                                <Column><Text text="{i18n>unit}" /></Column>
                                <Column><Text text="{i18n>poUnitPrice}" /></Column>
                                <Column><Text text="{i18n>poAmount}" /></Column>
                                <Column><Text text="{i18n>priceMatchStatus}" /></Column>
                                <Column><Text text="{i18n>poBenchmark}" /></Column>
                                <Column><Text text="{i18n>actions}" /></Column>
                            </columns>
                            <items>
                                <ColumnListItem>
                                    <cells>
                                        <Text text="{oNewPO>lineId}" />
                                        <Select selectedKey="{oNewPO>materialId}" change="onPricingConditionChange" items="{oNewPO>/materialOptions}" forceSelection="false">
                                            <items>
                                                <core:Item key="{oNewPO>id}" text="{= ${oNewPO>id} ? ${oNewPO>id} + ' - ' + ${oNewPO>name} : ${oNewPO>name} }" />
                                            </items>
                                        </Select>
                                        <Input value="{oNewPO>quantity}" type="Number" liveChange="onPricingConditionChange" />
                                        <Text text="{oNewPO>unit}" />
                                        <Text text="{= ${oNewPO>currency} + ' ' + ${oNewPO>unitPrice}}" />
                                        <Text text="{= ${oNewPO>currency} + ' ' + ${oNewPO>amount}}" />
                                        <ObjectStatus text="{ path: 'oNewPO>priceStatusText', formatter: '.formatPriceMatchText' }" state="{oNewPO>priceStatusState}" />
                                        <ObjectStatus text="{oNewPO>priceBenchmarkText}" state="{oNewPO>priceBenchmarkState}" />
                                        <Button icon="sap-icon://delete" type="Reject" press="onDeleteDraftItem" />
                                    </cells>
                                </ColumnListItem>
                            </items>
                        </Table>
                    </Panel>
                </VBox>
            </content>
            <beginButton>
                <Button text="{i18n>saveButton}" press="onDialogSave" type="Emphasized" />
            </beginButton>
            <endButton>
                <Button text="{i18n>cancelButton}" press="onDialogCancel" />
            </endButton>
        </Dialog>
    </Page>
</mvc:View>