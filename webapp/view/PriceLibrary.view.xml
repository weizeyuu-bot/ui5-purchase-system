<mvc:View
    controllerName="myapp.controller.PriceLibrary"
    xmlns:mvc="sap.ui.core.mvc"
    xmlns="sap.m">
    <Page title="{i18n>priceLibraryTitle}" showNavButton="true" navButtonPress="onNavBack">
        <subHeader>
            <Toolbar>
                <SearchField
                    width="100%"
                    placeholder="{i18n>priceSearchPlaceholder}"
                    search="onSearch"
                    liveChange="onSearch" />
                <Button
                    text="{i18n>priceAddRecord}"
                    icon="sap-icon://add"
                    type="Emphasized"
                    press="onAddPrice" />
            </Toolbar>
        </subHeader>
        <content>
            <Table id="priceTable" items="{priceLibrary>/priceRecords}" class="sapUiResponsiveContentPadding">
                <columns>
                    <Column width="90px"><Text text="ID" /></Column>
                    <Column width="180px"><Text text="{i18n>priceSupplier}" /></Column>
                    <Column width="160px"><Text text="{i18n>priceMaterial}" /></Column>
                    <Column width="110px"><Text text="{i18n>status}" /></Column>
                    <Column width="90px"><Text text="{i18n>priceUnit}" /></Column>
                    <Column width="110px"><Text text="{i18n>priceUnitPrice}" /></Column>
                    <Column width="120px"><Text text="{i18n>priceValidFrom}" /></Column>
                    <Column width="120px"><Text text="{i18n>priceValidTo}" /></Column>
                    <Column width="160px"><Text text="{i18n>priceRemark}" /></Column>
                    <Column width="140px"><Text text="{i18n>actions}" /></Column>
                </columns>
                <items>
                    <ColumnListItem>
                        <cells>
                            <Text text="{priceLibrary>id}" />
                            <VBox>
                                <Link text="{priceLibrary>supplierName}" press="onNavigateToSupplier" />
                                <Link text="{priceLibrary>supplierId}" press="onNavigateToSupplier" class="sapUiTinyMarginTop" />
                            </VBox>
                            <VBox>
                                <Link text="{priceLibrary>materialName}" press="onNavigateToMaterial" />
                                <Link text="{priceLibrary>materialId}" press="onNavigateToMaterial" class="sapUiTinyMarginTop" />
                            </VBox>
                            <ObjectStatus text="{priceLibrary>statusText}" state="{priceLibrary>statusState}" />
                            <Text text="{priceLibrary>unit}" />
                            <Text text="{= ${priceLibrary>currency} + ' ' + ${priceLibrary>unitPrice}}" />
                            <Text text="{priceLibrary>validFrom}" />
                            <Text text="{priceLibrary>validTo}" />
                            <Text text="{priceLibrary>remark}" />
                            <HBox>
                                <Button icon="sap-icon://edit" type="Transparent" press="onEditPrice" />
                                <Button icon="sap-icon://delete" type="Transparent" press="onDeletePrice" />
                            </HBox>
                        </cells>
                    </ColumnListItem>
                </items>
            </Table>
        </content>
    </Page>
</mvc:View>