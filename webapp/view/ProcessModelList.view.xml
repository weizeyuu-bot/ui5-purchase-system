<mvc:View
    controllerName="myapp.controller.ProcessModelList"
    xmlns:mvc="sap.ui.core.mvc"
    xmlns="sap.m"
    xmlns:core="sap.ui.core">
    <Page title="{i18n>processModelTitle}" showNavButton="true" navButtonPress="onNavBack">
        <VBox class="sapUiContentPadding" width="100%">
            <Text text="{i18n>processModelListTitle}" class="sapUiTinyMarginBottom" />
            <Table id="processModelTable" items="{processDisplay>/configuredProcessModels}" mode="SingleSelectLeft">
                <headerToolbar>
                    <Toolbar>
                        <ToolbarSpacer />
                        <Button text="{i18n>btnAdd}" icon="sap-icon://add" press="onAddModel" type="Emphasized" />
                        <Button text="{i18n>editButton}" icon="sap-icon://edit" press="onEditSelected" />
                        <Button text="{i18n>deleteButton}" icon="sap-icon://delete" type="Reject" press="onDeleteSelected" />
                    </Toolbar>
                </headerToolbar>
                <columns>
                    <Column><Text text="{i18n>processModelId}" /></Column>
                    <Column><Text text="{i18n>processModelName}" /></Column>
                    <Column><Text text="{i18n>deploymentLinkedForm}" /></Column>
                    <Column><Text text="{i18n>processInitiatorRole}" /></Column>
                    <Column><Text text="{i18n>processApproverRole}" /></Column>
                    <Column><Text text="{i18n>processModelVersion}" /></Column>
                    <Column><Text text="{i18n>processNodeCount}" /></Column>
                    <Column><Text text="{i18n>status}" /></Column>
                    <Column hAlign="Center"><Text text="{i18n>actions}" /></Column>
                </columns>
                <items>
                    <ColumnListItem type="Active" press="onRowPress">
                        <cells>
                            <Text text="{processDisplay>id}" />
                            <Text text="{processDisplay>name}" />
                            <Text text="{processDisplay>formName}" />
                            <Text text="{processDisplay>initiatorRole}" />
                            <Text text="{processDisplay>approverRole}" />
                            <Text text="{processDisplay>version}" />
                            <Text text="{processDisplay>nodeCount}" />
                            <Text text="{= ${processDisplay>status} === 'PUBLISHED' ? ${i18n>processStatusPublished} : ${processDisplay>status} === 'TESTING' ? ${i18n>processStatusTesting} : ${processDisplay>status} }" />
                            <HBox>
                                <Button text="{i18n>editButton}" icon="sap-icon://edit" press="onEditModel" class="sapUiTinyMarginEnd" />
                                <Button text="{i18n>deleteButton}" icon="sap-icon://delete" type="Reject" press="onDeleteModel" />
                            </HBox>
                        </cells>
                    </ColumnListItem>
                </items>
            </Table>
        </VBox>
    </Page>
</mvc:View>