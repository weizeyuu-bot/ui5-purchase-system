<mvc:View
    controllerName="myapp.controller.Home"
    xmlns:mvc="sap.ui.core.mvc"
    xmlns="sap.m"
    xmlns:layout="sap.ui.layout"
    xmlns:core="sap.ui.core">
    <Page title="{i18n>homeTitle}" showNavButton="false" class="homePage">
        <headerContent>
            <SegmentedButton id="langToggle" selectedKey="{view>/currentLang}" selectionChange="onLanguageToggle">
                <items>
                    <SegmentedButtonItem key="ZH" text="中" />
                    <SegmentedButtonItem key="EN" text="EN" />
                </items>
            </SegmentedButton>
            <Button text="{i18n>logoutButton}" type="Reject" press="onLogout" class="sapUiSmallMarginBegin" />
        </headerContent>
        <HBox class="homeMainContainer">
            <VBox class="homeMenuPanel" width="220px">
                <List selectionMode="None" class="navigationList">
                    <GroupHeaderListItem title="{i18n>menuGroupMasterData}" upperCase="false" />
                    <StandardListItem title="{i18n>menuSuppliers}" icon="sap-icon://tag" type="Navigation" press="onNavigateToSuppliers" />
                    <StandardListItem title="{i18n>menuMaterials}" icon="sap-icon://product" type="Navigation" press="onNavigateToMaterials" />
                    <StandardListItem title="{i18n>menuPriceLibrary}" icon="sap-icon://money-bills" type="Navigation" press="onNavigateToPriceLibrary" />
                    <StandardListItem title="{i18n>menuQuoteManagement}" icon="sap-icon://business-objects-experience" type="Navigation" press="onNavigateToQuoteManagement" />

                    <GroupHeaderListItem title="{i18n>menuGroupOperations}" upperCase="false" />
                    <StandardListItem title="{i18n>menuPurchaseOrders}" icon="sap-icon://documents" type="Navigation" press="onNavigateToPurchaseOrders" />
                    <StandardListItem title="{i18n>menuDeliveryPlans}" icon="sap-icon://shipping-status" type="Navigation" press="onNavigateToDeliveryPlans" />
                    <StandardListItem title="{i18n>menuInvoices}" icon="sap-icon://receipt" type="Navigation" press="onNavigateToInvoices" />

                    <GroupHeaderListItem title="{i18n>menuGroupGovernance}" upperCase="false" />
                    <StandardListItem title="{i18n>menuProfile}" icon="sap-icon://employee" type="Navigation" press="onNavigateToProfile" />
                    <StandardListItem title="{i18n>menuUserManagement}" icon="sap-icon://group" type="Navigation" press="onNavigateToUserManagement" />
                    <StandardListItem
                        id="processManagementParent"
                        title="{i18n>processManagementTitle}"
                        icon="{= ${view>/processMenuExpanded} ? 'sap-icon://navigation-up-arrow' : 'sap-icon://navigation-down-arrow'}"
                        type="Navigation"
                        press="onToggleProcessMenu"
                        class="parentMenuItem" />
                    <StandardListItem title="{i18n>processCategoriesTitle}" icon="sap-icon://activity-individual" type="Navigation" visible="{= ${view>/processMenuExpanded} }" press="onNavigateToProcessCategories" selected="{= ${view>/processMenuSelectedKey} === 'categories'}" class="subMenuItem" />
                    <StandardListItem title="{i18n>formConfigTitle}" icon="sap-icon://form" type="Navigation" visible="{= ${view>/processMenuExpanded} }" press="onNavigateToProcessFormConfigs" selected="{= ${view>/processMenuSelectedKey} === 'forms'}" class="subMenuItem" />
                    <StandardListItem title="{i18n>processModelTitle}" icon="sap-icon://process" type="Navigation" visible="{= ${view>/processMenuExpanded} }" press="onNavigateToProcessModels" selected="{= ${view>/processMenuSelectedKey} === 'models'}" class="subMenuItem" />
                    <StandardListItem title="{i18n>deploymentManagementTitle}" icon="sap-icon://sys-enter-2" type="Navigation" visible="{= ${view>/processMenuExpanded} }" press="onNavigateToProcessDeployments" selected="{= ${view>/processMenuSelectedKey} === 'deployment'}" class="subMenuItem" />
                    <StandardListItem title="{i18n>menuSystemManagement}" icon="sap-icon://settings" type="Navigation" press="onNavigateToSystemManagement" />
                </List>
            </VBox>

            <VBox class="homeContentArea" fitContainer="true">
                <VBox class="homeHeroPanel sapUiLargeMargin sapUiMediumMarginBegin sapUiMediumMarginEnd">
                    <Title text="{dashboard>/welcomeTitle}" level="H1" />
                    <Text text="{dashboard>/welcomeSubtitle}" class="dashboardHeroText sapUiSmallMarginTop" />
                    <HBox class="dashboardHeroMeta sapUiSmallMarginTop">
                        <ObjectStatus text="{dashboard>/todayText}" state="Information" />
                        <ObjectStatus text="{dashboard>/focusText}" state="Success" class="sapUiSmallMarginBegin" />
                    </HBox>
                </VBox>

                <Panel headerText="{i18n>dashboardOverviewSection}" class="sapUiLargeMargin sapUiMediumMarginBegin sapUiMediumMarginEnd dashboardPanel">
                    <HBox class="dashboardCardRow" wrap="Wrap" items="{dashboard>/summaryCards}">
                        <VBox class="dashboardInsightCard">
                            <HBox justifyContent="SpaceBetween" alignItems="Center">
                                <VBox>
                                    <Text text="{dashboard>title}" class="dashboardCardLabel" />
                                    <Title text="{dashboard>value}" level="H3" class="dashboardCardValue" />
                                </VBox>
                                <core:Icon src="{dashboard>icon}" size="1.6rem" class="dashboardCardIcon" />
                            </HBox>
                            <Text text="{dashboard>description}" class="dashboardCardDescription sapUiSmallMarginTop" />
                            <Link text="{i18n>viewButton}" press="onDashboardRoutePress" class="sapUiSmallMarginTop" />
                        </VBox>
                    </HBox>
                </Panel>

                <Panel headerText="{i18n>dashboardTodoSection}" class="sapUiLargeMargin sapUiMediumMarginBegin sapUiMediumMarginEnd dashboardPanel">
                    <HBox class="dashboardCardRow" wrap="Wrap" items="{dashboard>/todoCards}">
                        <VBox class="dashboardTodoCard">
                            <Text text="{dashboard>title}" class="dashboardCardLabel" />
                            <Title text="{dashboard>value}" level="H3" class="dashboardCardValue" />
                            <Text text="{dashboard>subtitle}" class="dashboardCardDescription" />
                            <ObjectStatus text="{dashboard>statusText}" state="{dashboard>statusState}" class="sapUiSmallMarginTop" />
                            <Link text="{i18n>dashboardHandleNow}" press="onDashboardRoutePress" class="sapUiSmallMarginTop" />
                        </VBox>
                    </HBox>
                </Panel>

                <HBox class="dashboardTwoColumnRow sapUiLargeMargin sapUiMediumMarginBegin sapUiMediumMarginEnd" wrap="Wrap">
                    <VBox class="dashboardColumnLeft">
                        <Panel headerText="{i18n>dashboardAlertSection}" class="dashboardPanel dashboardSubPanel">
                            <List items="{dashboard>/alerts}" noDataText="{i18n>dashboardNoAlerts}">
                                <StandardListItem title="{dashboard>title}" description="{dashboard>description}" info="{dashboard>info}" infoState="{dashboard>state}" icon="{dashboard>icon}" type="Navigation" press="onAlertPress" />
                            </List>
                        </Panel>

                        <Panel headerText="{i18n>recentActivities}" class="dashboardPanel dashboardSubPanel sapUiMediumMarginTop">
                            <List items="{dashboard>/activities}">
                                <StandardListItem title="{dashboard>title}" description="{dashboard>description}" icon="{dashboard>icon}" type="Navigation" press="onDashboardRoutePress" />
                            </List>
                        </Panel>
                    </VBox>

                    <VBox class="dashboardColumnRight">
                        <Panel headerText="{i18n>dashboardQuickEntrySection}" class="dashboardPanel dashboardSubPanel">
                            <List items="{dashboard>/quickActions}">
                                <StandardListItem title="{dashboard>title}" description="{dashboard>description}" icon="{dashboard>icon}" type="Navigation" press="onDashboardRoutePress" />
                            </List>
                        </Panel>

                        <Panel headerText="{i18n>topSuppliers}" class="dashboardPanel dashboardSubPanel sapUiMediumMarginTop">
                            <Table items="{dashboard>/topSuppliers}">
                                <columns>
                                    <Column><Text text="{i18n>supplierName}" /></Column>
                                    <Column><Text text="{i18n>contactCount}" /></Column>
                                    <Column><Text text="{i18n>orderValue}" /></Column>
                                    <Column><Text text="{i18n>status}" /></Column>
                                </columns>
                                <items>
                                    <ColumnListItem>
                                        <cells>
                                            <Text text="{dashboard>name}" />
                                            <Text text="{dashboard>contacts}" />
                                            <Text text="{dashboard>value}" />
                                            <ObjectStatus text="{dashboard>status}" state="{dashboard>state}" />
                                        </cells>
                                    </ColumnListItem>
                                </items>
                            </Table>
                        </Panel>
                    </VBox>
                </HBox>

                <Panel headerText="{i18n>dashboardExecutionSection}" class="sapUiLargeMargin sapUiMediumMarginBegin sapUiMediumMarginEnd dashboardPanel">
                    <Table items="{dashboard>/statusOverview}">
                        <columns>
                            <Column><Text text="{i18n>status}" /></Column>
                            <Column><Text text="{i18n>purchaseOrderCount}" /></Column>
                            <Column><Text text="{i18n>dashboardExecutionInsight}" /></Column>
                        </columns>
                        <items>
                            <ColumnListItem>
                                <cells>
                                    <Text text="{dashboard>label}" />
                                    <Text text="{dashboard>count}" />
                                    <Text text="{dashboard>description}" />
                                </cells>
                            </ColumnListItem>
                        </items>
                    </Table>
                </Panel>
            </VBox>
        </HBox>
    </Page>
</mvc:View>