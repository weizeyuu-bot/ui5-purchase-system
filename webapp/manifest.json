{
  "_version": "1.12.0",
  "sap.app": {
    "id": "myapp",
    "type": "application",
    "i18n": "i18n/i18n.properties",
    "applicationVersion": {
      "version": "1.0.0"
    },
    "title": "{{appTitle}}",
    "description": "{{appDescription}}",
    "sourceTemplate": {
      "id": "ui5template.basicSAPUI5ApplicationProject",
      "version": "1.40.12"
    }
  },
  "sap.ui": {
    "technology": "UI5",
    "icons": {
      "icon": "",
      "favIcon": "",
      "phone": "",
      "phone@2": "",
      "tablet": "",
      "tablet@2": ""
    },
    "deviceTypes": {
      "desktop": true,
      "tablet": true,
      "phone": true
    }
  },
  "sap.ui5": {
    "flexEnabled": false,
    "rootView": {
      "viewName": "myapp.view.App",
      "type": "XML",
      "async": true,
      "id": "App"
    },
    "dependencies": {
      "minUI5Version": "1.65.6",
      "libs": {
        "sap.ui.layout": {},
        "sap.ui.core": {},
        "sap.m": {},
        "sap.ui.unified": {}
      }
    },
    "contentDensities": {
      "compact": true,
      "cozy": true
    },
    "models": {
      "i18n": {
        "type": "sap.ui.model.resource.ResourceModel",
        "settings": {
          "bundleName": "myapp.i18n.i18n",
          "supportedLocales": ["en", ""],
          "fallbackLocale": ""
        }
      }
    },
    "resources": {
      "css": [
        {
          "uri": "css/style.css"
        }
      ]
    },
    "routing": {
      "config": {
        "routerClass": "sap.m.routing.Router",
        "viewType": "XML",
        "async": true,
        "viewPath": "myapp.view",
        "controlAggregation": "pages",
        "controlId": "app",
        "clearControlAggregation": true
      },
      "routes": [
        {
          "name": "RouteApp",
          "pattern": "",
          "target": [
            "TargetLogin"
          ]
        },
        {
          "name": "RouteLogin",
          "pattern": "login",
          "target": [
            "TargetLogin"
          ]
        },
        {
          "name": "RouteHome",
          "pattern": "home",
          "target": [
            "TargetHome"
          ]
        },
        {
          "name": "RouteSupplierList",
          "pattern": "suppliers",
          "target": [
            "TargetSupplierList"
          ]
        },
        {
          "name": "RouteSupplierDetail",
          "pattern": "suppliers/{supplierId}",
          "target": [
            "TargetSupplierDetail"
          ]
        },
        {
          "name": "RouteMaterialList",
          "pattern": "materials",
          "target": [
            "TargetMaterialList"
          ]
        },
        {
          "name": "RouteMaterialDetail",
          "pattern": "materials/{materialId}",
          "target": [
            "TargetMaterialDetail"
          ]
        },
        {
          "name": "RoutePurchaseOrderList",
          "pattern": "purchaseOrders",
          "target": [
            "TargetPurchaseOrderList"
          ]
        },
        {
          "name": "RoutePurchaseOrderDetail",
          "pattern": "purchaseOrders/{orderId}",
          "target": [
            "TargetPurchaseOrderDetail"
          ]
        },
        {
          "name": "RouteDeliveryPlanList",
          "pattern": "deliveryPlans",
          "target": [
            "TargetDeliveryPlanList"
          ]
        },
        {
          "name": "RouteDeliveryPlanDetail",
          "pattern": "deliveryPlans/{planId}",
          "target": [
            "TargetDeliveryPlanDetail"
          ]
        },
        {
          "name": "RouteInvoiceList",
          "pattern": "invoices",
          "target": [
            "TargetInvoiceList"
          ]
        },
        {
          "name": "RouteInvoiceDetail",
          "pattern": "invoices/{invoiceId}",
          "target": [
            "TargetInvoiceDetail"
          ]
        },
        {
          "name": "RouteProfile",
          "pattern": "profile",
          "target": [
            "TargetProfile"
          ]
        },
        {
          "name": "RouteUserManagement",
          "pattern": "userManagement/:tab:",
          "target": [
            "TargetUserManagement"
          ]
        },
        {
          "name": "RouteQuoteManagement",
          "pattern": "quoteManagement",
          "target": [
            "TargetQuoteManagement"
          ]
        },
        {
          "name": "RoutePriceLibrary",
          "pattern": "priceLibrary",
          "target": [
            "TargetPriceLibrary"
          ]
        },
        {
          "name": "RouteUserDetail",
          "pattern": "userManagement/{username}",
          "target": [
            "TargetUserDetail"
          ]
        },
        {
          "name": "RouteSystemManagement",
          "pattern": "systemManagement",
          "target": [
            "TargetSystemManagement"
          ]
        },
        {
          "name": "RouteProcessManagement",
          "pattern": "processManagement",
          "target": [
            "TargetProcessManagement"
          ]
        },
        {
          "name": "RouteProcessCategories",
          "pattern": "processManagement/categories",
          "target": [
            "TargetProcessCategories"
          ]
        },
        {
          "name": "RouteProcessFormConfigs",
          "pattern": "processManagement/formConfigs",
          "target": [
            "TargetProcessFormConfigs"
          ]
        },
        {
          "name": "RouteProcessModels",
          "pattern": "processManagement/models",
          "target": [
            "TargetProcessModels"
          ]
        },
        {
          "name": "RouteProcessModelCreate",
          "pattern": "processManagement/models/create",
          "target": [
            "TargetProcessModelDetail"
          ]
        },
        {
          "name": "RouteProcessModelDetail",
          "pattern": "processManagement/models/{modelId}",
          "target": [
            "TargetProcessModelDetail"
          ]
        },
        {
          "name": "RouteProcessDeployments",
          "pattern": "processManagement/deployments",
          "target": [
            "TargetProcessDeployments"
          ]
        }
      ],
      "targets": {
        "TargetLogin": {
          "viewType": "XML",
          "transition": "slide",
          "clearControlAggregation": true,
          "viewName": "Login"
        },
        "TargetHome": {
          "viewType": "XML",
          "transition": "slide",
          "clearControlAggregation": true,
          "viewName": "Home"
        },
        "TargetSupplierList": {
          "viewType": "XML",
          "transition": "slide",
          "clearControlAggregation": false,
          "viewName": "SupplierList"
        },
        "TargetSupplierDetail": {
          "viewType": "XML",
          "transition": "slide",
          "clearControlAggregation": false,
          "viewName": "SupplierDetail"
        },
        "TargetMaterialList": {
          "viewType": "XML",
          "transition": "slide",
          "clearControlAggregation": false,
          "viewName": "MaterialList"
        },
        "TargetMaterialDetail": {
          "viewType": "XML",
          "transition": "slide",
          "clearControlAggregation": false,
          "viewName": "MaterialDetail"
        },
        "TargetPurchaseOrderList": {
          "viewType": "XML",
          "transition": "slide",
          "clearControlAggregation": false,
          "viewName": "PurchaseOrderList"
        },
        "TargetPurchaseOrderDetail": {
          "viewType": "XML",
          "transition": "slide",
          "clearControlAggregation": false,
          "viewName": "PurchaseOrderDetail"
        },
        "TargetDeliveryPlanList": {
          "viewType": "XML",
          "transition": "slide",
          "clearControlAggregation": false,
          "viewName": "DeliveryPlanList"
        },
        "TargetDeliveryPlanDetail": {
          "viewType": "XML",
          "transition": "slide",
          "clearControlAggregation": false,
          "viewName": "DeliveryPlanDetail"
        },
        "TargetInvoiceList": {
          "viewType": "XML",
          "transition": "slide",
          "clearControlAggregation": false,
          "viewName": "InvoiceList"
        },
        "TargetInvoiceDetail": {
          "viewType": "XML",
          "transition": "slide",
          "clearControlAggregation": false,
          "viewName": "InvoiceDetail"
        },
        "TargetProfile": {
          "viewType": "XML",
          "transition": "slide",
          "clearControlAggregation": false,
          "viewName": "Profile"
        },
        "TargetUserManagement": {
          "viewType": "XML",
          "transition": "slide",
          "clearControlAggregation": false,
          "viewName": "UserManagement"
        },
        "TargetQuoteManagement": {
          "viewType": "XML",
          "transition": "slide",
          "clearControlAggregation": false,
          "viewName": "QuoteManagement"
        },
        "TargetPriceLibrary": {
          "viewType": "XML",
          "transition": "slide",
          "clearControlAggregation": false,
          "viewName": "PriceLibrary"
        },
        "TargetUserDetail": {
          "viewType": "XML",
          "transition": "slide",
          "clearControlAggregation": false,
          "viewName": "UserDetail"
        },
        "TargetSystemManagement": {
          "viewType": "XML",
          "transition": "slide",
          "clearControlAggregation": false,
          "viewName": "SystemManagement"
        },
        "TargetProcessManagement": {
          "viewType": "XML",
          "transition": "slide",
          "clearControlAggregation": false,
          "viewName": "ProcessManagement"
        },
        "TargetProcessCategories": {
          "viewType": "XML",
          "transition": "slide",
          "clearControlAggregation": false,
          "viewName": "ProcessCategories"
        },
        "TargetProcessFormConfigs": {
          "viewType": "XML",
          "transition": "slide",
          "clearControlAggregation": false,
          "viewName": "FormConfig"
        },
        "TargetProcessModels": {
          "viewType": "XML",
          "transition": "slide",
          "clearControlAggregation": false,
          "viewName": "ProcessModelList"
        },
        "TargetProcessModelDetail": {
          "viewType": "XML",
          "transition": "slide",
          "clearControlAggregation": false,
          "viewName": "ProcessModelDetail"
        },
        "TargetProcessDeployments": {
          "viewType": "XML",
          "transition": "slide",
          "clearControlAggregation": false,
          "viewName": "DeploymentList"
        }
      }
    }
  }
}