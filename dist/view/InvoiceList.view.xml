<mvc:View
    controllerName="myapp.controller.InvoiceList"
    xmlns:mvc="sap.ui.core.mvc"
    xmlns="sap.m"
    xmlns:core="sap.ui.core">
    <Page title="{i18n>invoiceListTitle}" showNavButton="true" navButtonPress="onNavBack">
        <subHeader>
            <Toolbar>
                <Button icon="sap-icon://add" text="{i18n>btnAdd}" press="onAdd" type="Emphasized" />
                <SearchField placeholder="{i18n>filterPlaceholder}" search="onSearch" width="100%" />
            </Toolbar>
        </subHeader>
        <content>
            <Table id="invoiceTable" class="supplierTable" items="{invoices>/invoices}">
                <columns>
                    <Column>
                        <Text text="{i18n>invoiceId}" />
                    </Column>
                    <Column>
                        <Text text="{i18n>invoiceDate}" />
                    </Column>
                    <Column>
                        <Text text="{i18n>invoiceAmount}" />
                    </Column>
                    <Column>
                        <Text text="{i18n>invoiceStatus}" />
                    </Column>
                    <Column>
                        <Text text="{i18n>poId}" />
                    </Column>
                    <Column>
                        <Text text="{i18n>deliveryId}" />
                    </Column>
                    <Column>
                        <Text text="{i18n>poItemCount}" />
                    </Column>
                </columns>
                <items>
                    <ColumnListItem type="Navigation" press="onItemPress">
                        <cells>
                            <Text text="{invoices>id}" />
                            <Text text="{invoices>date}" />
                            <Text text="{invoices>amount}" />
                            <Text text="{ path: 'invoices>status', formatter: '.formatInvoiceStatusText' }" />
                            <Link text="{invoices>purchaseOrderId}" press="onNavigateToPurchaseOrder" />
                            <Link text="{invoices>deliveryPlanId}" press="onNavigateToDeliveryPlan" />
                            <Text text="{invoices>itemCount}" />
                            <HBox>
                                <Button text="{i18n>viewButton}" press="onViewPress" />
                                <Button text="{i18n>editButton}" press="onEditPress" />
                                <Button icon="sap-icon://delete" type="Reject" press="onDeletePress" />
                            </HBox>
                        </cells>
                    </ColumnListItem>
                </items>
            </Table>
        </content>
        <Dialog id="invoiceDialog" title="{i18n>menuInvoices}" type="Standard">
            <content>
                <VBox class="sapUiContentPadding">
                    <Panel headerText="{i18n>invoiceHeaderSection}">
                        <VBox class="sapUiSmallMargin">
                            <Label text="{i18n>invoiceId}" required="true" />
                            <Input id="invNumberInput" value="{oNewInvoice>/invoiceNumber}" />
                            <Label text="{i18n>invoiceDate}" />
                            <DatePicker value="{oNewInvoice>/date}" valueFormat="yyyy-MM-dd" displayFormat="yyyy-MM-dd" />
                            <Label text="{i18n>status}" />
                            <Select id="invStatusInput" selectedKey="{oNewInvoice>/status}" forceSelection="false">
                                <items>
                                    <core:Item key="" text="{i18n>pleaseSelect}" />
                                    <core:Item key="PENDING" text="{i18n>invoiceStatusPending}" />
                                    <core:Item key="INVOICED" text="{i18n>invoiceStatusInvoiced}" />
                                    <core:Item key="VOID" text="{i18n>invoiceStatusVoided}" />
                                </items>
                            </Select>
                            <Label text="{i18n>poItemCount}" />
                            <Input value="{oNewInvoice>/itemCount}" editable="false" />
                            <Label text="{i18n>invoiceAmount}" />
                            <Input id="invAmountInput" value="{oNewInvoice>/amount}" editable="false" />
                        </VBox>
                    </Panel>

                    <Panel headerText="{i18n>invoiceLineItemsSection}" class="sapUiSmallMarginTop">
                        <headerToolbar>
                            <Toolbar>
                                <Title text="{i18n>invoiceLineItemsSection}" level="H4" />
                                <ToolbarSpacer />
                                <Button text="{i18n>btnAdd}" icon="sap-icon://add" press="onAddDraftItem" />
                            </Toolbar>
                        </headerToolbar>
                        <Table items="{oNewInvoice>/items}">
                            <columns>
                                <Column><Text text="{i18n>poLineNo}" /></Column>
                                <Column><Text text="{i18n>poId}" /></Column>
                                <Column><Text text="{i18n>deliveryId}" /></Column>
                                <Column><Text text="{i18n>invoiceAmount}" /></Column>
                                <Column><Text text="{i18n>actions}" /></Column>
                            </columns>
                            <items>
                                <ColumnListItem>
                                    <cells>
                                        <Text text="{oNewInvoice>lineId}" />
                                        <Select selectedKey="{oNewInvoice>purchaseOrderId}" items="{oNewInvoice>/purchaseOrderOptions}" forceSelection="false" change="onDraftItemChange">
                                            <items>
                                                <core:Item key="{oNewInvoice>id}" text="{oNewInvoice>name}" />
                                            </items>
                                        </Select>
                                        <Select selectedKey="{oNewInvoice>deliveryPlanId}" items="{oNewInvoice>/deliveryPlanOptions}" forceSelection="false" change="onDraftItemChange">
                                            <items>
                                                <core:Item key="{oNewInvoice>id}" text="{oNewInvoice>name}" />
                                            </items>
                                        </Select>
                                        <Input value="{oNewInvoice>amount}" type="Number" liveChange="onDraftItemChange" />
                                        <Button icon="sap-icon://delete" type="Reject" press="onDeleteDraftItem" />
                                    </cells>
                                </ColumnListItem>
                            </items>
                        </Table>
                    </Panel>
                </VBox>
            </content>
            <beginButton>
                <Button text="{i18n>saveButton}" press="onDialogSave" type="Emphasized" />
            </beginButton>
            <endButton>
                <Button text="{i18n>cancelButton}" press="onDialogCancel" />
            </endButton>
        </Dialog>
    </Page>
</mvc:View>