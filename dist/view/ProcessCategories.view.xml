<mvc:View
    controllerName="myapp.controller.ProcessCategories"
    xmlns:mvc="sap.ui.core.mvc"
    xmlns="sap.m"
    xmlns:core="sap.ui.core">
    <Page title="流程分类" showNavButton="true" navButtonPress="onNavBack">
        <VBox class="sapUiContentPadding" width="100%">
            <Text text="流程分类列表" class="sapUiTinyMarginBottom" />
            <Table items="{process>/processCategories}">
                <columns>
                    <Column><Text text="分类编号" /></Column>
                    <Column><Text text="分类名称" /></Column>
                </columns>
                <items>
                    <ColumnListItem>
                        <cells>
                            <Text text="{process>id}" />
                            <Text text="{process>name}" />
                        </cells>
                    </ColumnListItem>
                </items>
            </Table>
        </VBox>
    </Page>
</mvc:View>