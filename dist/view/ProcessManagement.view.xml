<mvc:View
    controllerName="myapp.controller.ProcessManagement"
    xmlns:mvc="sap.ui.core.mvc"
    xmlns="sap.m"
    xmlns:layout="sap.ui.layout"
    xmlns:core="sap.ui.core">
    <Page title="{i18n>processManagementTitle}" showNavButton="true" navButtonPress="onNavBack">
        <VBox class="sapUiContentPadding">
            <TabContainer id="processTabContainer" selectedKey="categories">
                <items>
                    <TabContainerItem key="categories" name="{i18n>processCategoriesTitle}">
                        <content>
                            <Table items="{process>/processCategories}">
                                <columns>
                                    <Column><Text text="{i18n>processCategoryId}" /></Column>
                                    <Column><Text text="{i18n>processCategoryName}" /></Column>
                                    <Column><Text text="{i18n>processCategoryDescription}" /></Column>
                                    <Column><Text text="{i18n>processOwner}" /></Column>
                                </columns>
                                <items>
                                    <ColumnListItem>
                                        <cells>
                                            <Text text="{process>id}" />
                                            <Text text="{process>name}" />
                                            <Text text="{process>description}" />
                                            <Text text="{process>owner}" />
                                        </cells>
                                    </ColumnListItem>
                                </items>
                            </Table>
                        </content>
                    </TabContainerItem>
                    <TabContainerItem key="forms" name="{i18n>formConfigTitle}">
                        <content>
                            <Table items="{process>/formConfigs}">
                            <columns>
                                <Column><Text text="{i18n>formId}" /></Column>
                                <Column><Text text="{i18n>formName}" /></Column>
                                <Column><Text text="{i18n>formBusinessObject}" /></Column>
                                <Column><Text text="{i18n>processInitiatorRole}" /></Column>
                                <Column><Text text="{i18n>processApproverRole}" /></Column>
                                <Column><Text text="{i18n>formFields}" /></Column>
                            </columns>
                            <items>
                                <ColumnListItem>
                                    <cells>
                                        <Text text="{process>id}" />
                                        <Text text="{process>name}" />
                                        <Text text="{process>businessObject}" />
                                        <Text text="{process>initiatorRole}" />
                                        <Text text="{process>approverRole}" />
                                        <Text text="{= ${process>fields}.join(', ') }" />
                                    </cells>
                                </ColumnListItem>
                            </items>
                        </Table>
                        </content>
                    </TabContainerItem>
                    <TabContainerItem key="models" name="{i18n>processModelTitle}">
                        <content>
                            <Table items="{process>/processModels}">
                            <columns>
                                <Column><Text text="{i18n>processModelId}" /></Column>
                                <Column><Text text="{i18n>processModelName}" /></Column>
                                <Column><Text text="{i18n>processBusinessObject}" /></Column>
                                <Column><Text text="{i18n>processInitiatorRole}" /></Column>
                                <Column><Text text="{i18n>processApproverRole}" /></Column>
                                <Column><Text text="{i18n>processModelVersion}" /></Column>
                                <Column><Text text="{i18n>processNodeCount}" /></Column>
                                <Column><Text text="{i18n>status}" /></Column>
                            </columns>
                            <items>
                                <ColumnListItem>
                                    <cells>
                                        <Text text="{process>id}" />
                                        <Text text="{process>name}" />
                                        <Text text="{process>businessObject}" />
                                        <Text text="{process>initiatorRole}" />
                                        <Text text="{process>approverRole}" />
                                        <Text text="{process>version}" />
                                        <Text text="{process>nodeCount}" />
                                        <Text text="{= ${process>status} === 'PUBLISHED' ? ${i18n>processStatusPublished} : ${process>status} === 'TESTING' ? ${i18n>processStatusTesting} : ${process>status} }" />
                                    </cells>
                                </ColumnListItem>
                            </items>
                        </Table>
                        <Panel headerText="{i18n>processNodeConfigTitle}" class="sapUiMediumMarginTop">
                            <Table items="{process>/processNodes}">
                                <columns>
                                    <Column><Text text="{i18n>processNodeId}" /></Column>
                                    <Column><Text text="{i18n>processNodeName}" /></Column>
                                    <Column><Text text="{i18n>processNodeType}" /></Column>
                                    <Column><Text text="{i18n>processNodeAction}" /></Column>
                                    <Column><Text text="{i18n>processNodeAssigneeRole}" /></Column>
                                    <Column><Text text="{i18n>processNodeSla}" /></Column>
                                </columns>
                                <items>
                                    <ColumnListItem>
                                        <cells>
                                            <Text text="{process>nodeId}" />
                                            <Text text="{process>nodeName}" />
                                            <Text text="{process>nodeType}" />
                                            <Text text="{process>nodeAction}" />
                                            <Text text="{process>assigneeRole}" />
                                            <Text text="{= ${process>sla} + ' ' + ${i18n>daysUnit} }" />
                                        </cells>
                                    </ColumnListItem>
                                </items>
                            </Table>
                        </Panel>
                        </content>
                    </TabContainerItem>
                    <TabContainerItem key="deployment" name="{i18n>deploymentManagementTitle}">
                        <content>
                            <Table items="{process>/deployments}">
                            <columns>
                                <Column><Text text="{i18n>deploymentId}" /></Column>
                                <Column><Text text="{i18n>processModelName}" /></Column>
                                <Column><Text text="{i18n>deploymentEnvironment}" /></Column>
                                <Column><Text text="{i18n>deploymentScope}" /></Column>
                                <Column><Text text="{i18n>deploymentTime}" /></Column>
                                <Column><Text text="{i18n>publishedBy}" /></Column>
                                <Column><Text text="{i18n>status}" /></Column>
                            </columns>
                            <items>
                                <ColumnListItem>
                                    <cells>
                                        <Text text="{process>id}" />
                                        <Text text="{process>modelName}" />
                                        <Text text="{process>environment}" />
                                        <Text text="{process>scope}" />
                                        <Text text="{process>deployTime}" />
                                        <Text text="{process>publishedBy}" />
                                        <ObjectStatus text="{= ${process>status} === 'SUCCESS' ? ${i18n>deployStatusSuccess} : ${process>status} === 'FAILED' ? ${i18n>deployStatusFailed} : ${process>status} }" state="{= ${process>status} === 'SUCCESS' ? 'Success' : ${process>status} === 'FAILED' ? 'Error' : 'Information' }" />
                                    </cells>
                                </ColumnListItem>
                            </items>
                        </Table>
                        <Panel headerText="{i18n>processInstanceTitle}" class="sapUiMediumMarginTop">
                            <Table items="{process>/processInstances}">
                                <columns>
                                    <Column><Text text="{i18n>processInstanceId}" /></Column>
                                    <Column><Text text="{i18n>processModelName}" /></Column>
                                    <Column><Text text="{i18n>poId}" /></Column>
                                    <Column><Text text="{i18n>processCurrentNode}" /></Column>
                                    <Column><Text text="{i18n>processInitiator}" /></Column>
                                    <Column><Text text="{i18n>processCurrentHandler}" /></Column>
                                    <Column><Text text="{i18n>processSubmittedAt}" /></Column>
                                    <Column><Text text="{i18n>status}" /></Column>
                                </columns>
                                <items>
                                    <ColumnListItem>
                                        <cells>
                                            <Text text="{process>instanceId}" />
                                            <Text text="{process>modelName}" />
                                            <Text text="{process>businessId}" />
                                            <Text text="{process>currentNode}" />
                                            <Text text="{= ${process>initiator} + ' / ' + ${process>initiatorRole} }" />
                                            <Text text="{process>currentHandler}" />
                                            <Text text="{process>submittedAt}" />
                                            <ObjectStatus text="{process>statusText}" state="{process>statusState}" />
                                        </cells>
                                    </ColumnListItem>
                                </items>
                            </Table>
                        </Panel>
                        </content>
                    </TabContainerItem>
                </items>
            </TabContainer>
        </VBox>
    </Page>
</mvc:View>