<mvc:View
    controllerName="myapp.controller.ProcessModelList"
    xmlns:mvc="sap.ui.core.mvc"
    xmlns="sap.m"
    xmlns:core="sap.ui.core">
    <Page title="流程模型" showNavButton="true" navButtonPress="onNavBack">
        <VBox class="sapUiContentPadding" width="100%">
            <Text text="流程模型列表" class="sapUiTinyMarginBottom" />
            <Table items="{process>/processModels}">
                <columns>
                    <Column><Text text="模型ID" /></Column>
                    <Column><Text text="模型名称" /></Column>
                    <Column><Text text="版本" /></Column>
                    <Column><Text text="状态" /></Column>
                </columns>
                <items>
                    <ColumnListItem>
                        <cells>
                            <Text text="{process>id}" />
                            <Text text="{process>name}" />
                            <Text text="{process>version}" />
                            <Text text="{process>status}" />
                        </cells>
                    </ColumnListItem>
                </items>
            </Table>
        </VBox>
    </Page>
</mvc:View>