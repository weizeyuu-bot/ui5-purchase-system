<mvc:View
    controllerName="myapp.controller.DeliveryPlanDetail"
    xmlns:mvc="sap.ui.core.mvc"
    xmlns="sap.m"
    xmlns:core="sap.ui.core">
    <Page title="{i18n>deliveryPlanListTitle}" showNavButton="true" navButtonPress="onNavBack" class="poDetailPage">
        <content>
            <VBox class="poDetailLayout">
                <HBox class="poDetailTopRow" wrap="Wrap" renderType="Bare">
                    <Panel class="poDetailHeaderPanel poHeaderBandPanel">
                        <headerToolbar>
                            <Toolbar class="poHeaderBandToolbar">
                                <Title text="{i18n>deliveryHeaderSection}" level="H4" />
                                <ToolbarSpacer />
                                <ObjectStatus text="{ path: 'deliveryPlans>status', formatter: '.formatDeliveryStatusText' }" class="poHeaderBandStatus" />
                            </Toolbar>
                        </headerToolbar>
                        <FlexBox wrap="Wrap" renderType="Bare" class="poHeaderBandGrid">
                            <VBox class="poHeaderField poHeaderFieldShort">
                                <Text text="{i18n>deliveryId}" class="poHeaderFieldLabel" />
                                <Input value="{deliveryPlans>id}" editable="false" class="poHeaderFieldInput" />
                            </VBox>
                            <VBox class="poHeaderField poHeaderFieldShort">
                                <Text text="{i18n>deliveryDate}" class="poHeaderFieldLabel" />
                                <DatePicker value="{deliveryPlans>date}" valueFormat="yyyy-MM-dd" displayFormat="yyyy-MM-dd" class="poHeaderFieldInput" />
                            </VBox>
                            <VBox class="poHeaderField poHeaderFieldShort">
                                <Text text="{i18n>deliveryStatus}" class="poHeaderFieldLabel" />
                                <Select selectedKey="{deliveryPlans>status}" class="poHeaderFieldInput">
                                    <items>
                                        <core:Item key="PENDING" text="{i18n>deliveryStatusPending}" />
                                        <core:Item key="SHIPPED" text="{i18n>deliveryStatusShipped}" />
                                        <core:Item key="IN_TRANSIT" text="{i18n>deliveryStatusInTransit}" />
                                        <core:Item key="DELIVERED" text="{i18n>deliveryStatusDelivered}" />
                                    </items>
                                </Select>
                            </VBox>
                        </FlexBox>
                    </Panel>

                    <VBox class="poDetailSummaryColumn">
                        <Panel class="poSummaryHeroPanel">
                            <VBox class="poSummaryHeroContent">
                                <Text text="{i18n>deliveryStatus}" class="poSummaryEyebrow" />
                                <ObjectStatus text="{ path: 'deliveryPlans>status', formatter: '.formatDeliveryStatusText' }" class="poSummaryStatus" />
                                <Title text="{deliveryPlans>id}" level="H3" class="poSummaryTitle sapUiSmallMarginTop" />
                                <Text text="{deliveryPlans>date}" class="poSummarySubtext sapUiTinyMarginTop" />
                            </VBox>
                        </Panel>

                        <HBox class="poMetricGrid" wrap="Wrap" renderType="Bare">
                            <VBox class="poMetricCard">
                                <Text text="{i18n>poItemCount}" class="poMetricLabel" />
                                <Title text="{deliveryPlans>itemCount}" level="H3" class="poMetricValue" />
                            </VBox>
                            <VBox class="poMetricCard poMetricCardWide">
                                <Text text="{i18n>poTotalQuantity}" class="poMetricLabel" />
                                <Title text="{deliveryPlans>totalQuantity}" level="H3" class="poMetricValue" />
                            </VBox>
                        </HBox>
                    </VBox>
                </HBox>

                <Panel headerText="{i18n>deliveryLineItemsSection}" class="poLineItemsPanel">
                    <headerToolbar>
                        <Toolbar class="poLineItemsToolbar">
                            <Title text="{i18n>deliveryLineItemsSection}" level="H4" />
                            <ToolbarSpacer />
                            <Button text="{i18n>btnAdd}" icon="sap-icon://add" press="onAddItem" />
                        </Toolbar>
                    </headerToolbar>
                    <Table items="{deliveryPlans>items}" class="poLineItemsTable">
                        <columns>
                            <Column width="5rem" hAlign="Center"><Text text="{i18n>poLineNo}" /></Column>
                            <Column width="18rem"><Text text="{i18n>poId}" /></Column>
                            <Column width="10rem" hAlign="End"><Text text="{i18n>poQuantity}" /></Column>
                            <Column width="5rem" hAlign="Center"><Text text="{i18n>actions}" /></Column>
                        </columns>
                        <items>
                            <ColumnListItem class="poLineItemRow">
                                <cells>
                                    <Text text="{deliveryPlans>lineId}" textAlign="Center" class="poCellText" />
                                    <Select selectedKey="{deliveryPlans>purchaseOrderId}" items="{selectOptions>/purchaseOrderOptions}" forceSelection="false" change="onItemChange" class="poCellSelect">
                                        <items>
                                            <core:Item key="{selectOptions>id}" text="{= ${selectOptions>id} ? ${selectOptions>id} + ' - ' + ${selectOptions>name} : ${selectOptions>name} }" />
                                        </items>
                                    </Select>
                                    <Input value="{deliveryPlans>quantity}" type="Number" liveChange="onItemChange" textAlign="End" class="poCellInput poCellNumber" />
                                    <Button icon="sap-icon://delete" type="Reject" press="onDeleteItem" class="poRowDeleteButton" />
                                </cells>
                            </ColumnListItem>
                        </items>
                    </Table>
                </Panel>
                <HBox justifyContent="End" class="poDetailActionBar" renderType="Bare">
                    <Button text="{i18n>saveButton}" press="onSave" type="Emphasized" class="sapUiTinyMarginEnd" />
                    <Button text="{i18n>cancelButton}" press="onCancel" />
                </HBox>
            </VBox>
        </content>
    </Page>
</mvc:View>