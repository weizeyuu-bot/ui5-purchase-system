<mvc:View
    controllerName="myapp.controller.InvoiceDetail"
    xmlns:mvc="sap.ui.core.mvc"
    xmlns="sap.m"
    xmlns:f="sap.ui.layout.form">
    <Page title="{i18n>invoiceListTitle}" showNavButton="true" navButtonPress="onNavBack">
        <content>
            <VBox class="detailForm">
                <f:SimpleForm editable="true" layout="ResponsiveGridLayout" labelSpanXL="4" labelSpanL="4" labelSpanM="4" labelSpanS="12" adjustLabelSpan="false" emptySpanXL="0" emptySpanL="0" emptySpanM="0" emptySpanS="0" columnsXL="1" columnsL="1" columnsM="1" singleContainerFullSize="false">
                    <f:content>
                        <Label text="{i18n>invoiceId}" />
                        <Input value="{invoices>id}" editable="false" />
                        <Label text="{i18n>invoiceDate}" />
                        <Input value="{invoices>date}" />
                        <Label text="{i18n>invoiceAmount}" />
                        <Input value="{invoices>amount}" />
                        <Label text="{i18n>invoiceStatus}" />
                        <Input value="{invoices>status}" />
                        <Label text="{i18n>poId}" />
                        <Link text="{invoices>purchaseOrderId}" press="onNavigateToPurchaseOrder" />
                        <Label text="{i18n>deliveryId}" />
                        <Link text="{invoices>deliveryPlanId}" press="onNavigateToDeliveryPlan" />
                    </f:content>
                </f:SimpleForm>
                <HBox justifyContent="End" class="sapUiSmallMarginTop">
                    <Button text="{i18n>saveButton}" press="onSave" type="Emphasized" />
                    <Button text="{i18n>cancelButton}" press="onCancel" />
                </HBox>
            </VBox>
        </content>
    </Page>
</mvc:View>